# Base URL of the Ollama OpenAI-compatible API endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use for the agent. Must support OpenAI-style tool/function calling.
MODEL_NAME=qwen2.5-coder:14b

# Base URL of the (mock) RAG API server.
RAG_API_URL=http://localhost:8000

# Maximum number of agent-loop iterations before giving up.
MAX_ITERATIONS=10

# Directory (relative or absolute) where per-session code is written.
WORKSPACE_ROOT=workspace

# Directory where a JSON run log is written per /generate-code request.
LOGS_DIR=logs

# Timeouts, in seconds.
RAG_REQUEST_TIMEOUT=10
WEB_SEARCH_TIMEOUT=10
TEST_RUN_TIMEOUT=60
ENDPOINT_TIMEOUT=300

# The OpenAI SDK requires a non-empty API key even though Ollama ignores it.
OPENAI_API_KEY=ollama

# Tavily API key for web_search (get one at tavily.com). Optional - if unset,
# web_search automatically falls back to DuckDuckGo (no key needed).
TAVILY_API_KEY=
