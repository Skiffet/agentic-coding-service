# Base URL of the Ollama OpenAI-compatible API endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use for the agent. Must support OpenAI-style tool/function calling.
# qwen2.5-coder-16k is qwen2.5-coder:14b with num_ctx baked in via
# ollama/Modelfile (see the setup step below and OLLAMA_NUM_CTX further
# down for why a plain model tag isn't enough).
MODEL_NAME=qwen2.5-coder-16k

# Base URL of the (mock) RAG API server.
RAG_API_URL=http://localhost:8000

# Maximum number of agent-loop iterations before giving up. Not every
# iteration makes progress (malformed JSON, a rejected filename, etc. waste
# some), so this is set higher than the number of real attempts you'd expect
# to need.
MAX_ITERATIONS=16
# Iteration budget for refining an existing session (smaller task, smaller budget).
REFINE_MAX_ITERATIONS=10

# Context window (tokens) requested from Ollama per call. Ollama's own
# default (4096) is much smaller than qwen2.5-coder:14b's actual max (32768)
# and can be too small for a long multi-iteration agent loop - once exceeded,
# Ollama silently truncates the oldest messages instead of erroring, which
# can look like the model "forgetting" earlier context. Uses more VRAM the
# higher it's set.
OLLAMA_NUM_CTX=16384

# Directory (relative or absolute) where per-session code is written.
WORKSPACE_ROOT=workspace

# Directory where a JSON run log is written per /generate-code request.
LOGS_DIR=logs

# Timeouts, in seconds.
RAG_REQUEST_TIMEOUT=10
WEB_SEARCH_TIMEOUT=10
TEST_RUN_TIMEOUT=60
ENDPOINT_TIMEOUT=480

# The OpenAI SDK requires a non-empty API key even though Ollama ignores it.
OPENAI_API_KEY=ollama

# Tavily API key for web_search (get one at tavily.com). Optional - if unset,
# web_search automatically falls back to DuckDuckGo (no key needed).
TAVILY_API_KEY=

# run_tests executes model-controlled shell commands, so by default it runs
# them inside an isolated Docker sandbox (see docker/sandbox.Dockerfile) -
# no network, memory/CPU/process limits, read-only filesystem outside the
# workspace mount. Requires building the image once:
#   docker build -f docker/sandbox.Dockerfile -t agentic-sandbox:latest .
# Set to false only if Docker isn't available (commands then run directly on
# the host shell - understand the command-injection risk before doing that).
SANDBOX_ENABLED=true
SANDBOX_IMAGE=agentic-sandbox:latest
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_PIDS_LIMIT=128
